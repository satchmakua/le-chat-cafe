# EditorConfig — consistent formatting across editors. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{py,rs}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false  # trailing spaces are meaningful (hard line breaks)

[Makefile]
indent_style = tab
