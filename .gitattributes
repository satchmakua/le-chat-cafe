# Auto detect text files and perform LF normalization
* text=auto

# Keep shell scripts LF even on Windows checkouts
*.sh text eol=lf

# Treat common binary assets as binary (no EOL munging, no bad diffs)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.mp3 binary
*.wav binary
*.ogg binary
*.mp4 binary
*.glb binary
*.gltf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.pdf binary
